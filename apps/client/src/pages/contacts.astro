---
import ContactList from '../features/contacts/ContactList.astro';
import CreateContact from '../features/contacts/CreateContact.astro';
import PageLayout from '../layout/PageLayout.astro';
---

<PageLayout>
  <main
    id="main-container"
    class="flex flex-col p-4 max-w-360 mx-auto gap-8 md:items-center min-h-[calc(100vh-5rem)]"
  >
    <CreateContact />
    <ContactList />
  </main>
</PageLayout>

<script>
  import authService from '../features/auth/auth.service';
  authService.getLoggedUser();
</script>
